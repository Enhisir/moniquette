{
  "Kestrel": {
    "Endpoints": {
      "HttpEndpoint": {
        "Url": "http://localhost:8080",
        "Protocols": "Http1"
      },
      "GrpcEndpoint": {
        "Url": "http://localhost:5050",
        "Protocols": "Http2"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Moniquette.Server",
    "Audience": "Moniquette.Client",
    "Secret": "development-only-moniquette-jwt-secret-change-me",
    "TokenLifetimeMinutes": 240
  },
  "Urls": {
    "ElasticSearch": "http://localhost:9200",
    "Loki": ""
  },
  "NetworkPolicy": {
    "RequiredConnectionCount": 1,
    "AllowedConnections": []
  }
}
