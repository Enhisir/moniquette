#!/bin/sh
# Educational whitelist manager for OpenWrt/fw4/nftables.
# POSIX sh / BusyBox-compatible.

set -u

BASE_DIR="/etc/edu-whitelist"
DOMAINS_FILE="$BASE_DIR/domains.txt"
IPS_FILE="$BASE_DIR/ips.txt"
CONF_FILE="$BASE_DIR/config"
STATE_DIR="/tmp/edu-whitelist"
NFT_FILE="$STATE_DIR/rules.nft"
TABLE_NAME="edu_whitelist"
INIT_FILE="/etc/init.d/edu-whitelist"
CRON_FILE="/etc/crontabs/root"

DEFAULT_LAN_IF="br-lan"
DEFAULT_WAN_IF="wan"
DEFAULT_ENABLE_IPV6="0"
DEFAULT_AUTO_UPDATE_HOUR="6"

log() { printf '%s\n' "[edu-whitelist] $*"; }
err() { printf '%s\n' "[edu-whitelist] ERROR: $*" >&2; }

require_root() {
  if [ "$(id -u)" != "0" ]; then
    err "run as root"
    exit 1
  fi
}

ensure_dirs() {
  mkdir -p "$BASE_DIR" "$STATE_DIR"
  [ -f "$DOMAINS_FILE" ] || touch "$DOMAINS_FILE"
  [ -f "$IPS_FILE" ] || touch "$IPS_FILE"
  if [ ! -f "$CONF_FILE" ]; then
    cat > "$CONF_FILE" <<CFG
LAN_IF="$DEFAULT_LAN_IF"
WAN_IF="$DEFAULT_WAN_IF"
ENABLE_IPV6="$DEFAULT_ENABLE_IPV6"
AUTO_UPDATE_HOUR="$DEFAULT_AUTO_UPDATE_HOUR"
# Optional: URL with domains.txt-compatible content. Empty by default.
REMOTE_DOMAINS_URL=""
CFG
  fi
}

load_config() {
  ensure_dirs
  # shellcheck source=/dev/null
  . "$CONF_FILE"
  LAN_IF="${LAN_IF:-$DEFAULT_LAN_IF}"
  WAN_IF="${WAN_IF:-$DEFAULT_WAN_IF}"
  ENABLE_IPV6="${ENABLE_IPV6:-$DEFAULT_ENABLE_IPV6}"
  AUTO_UPDATE_HOUR="${AUTO_UPDATE_HOUR:-$DEFAULT_AUTO_UPDATE_HOUR}"
  REMOTE_DOMAINS_URL="${REMOTE_DOMAINS_URL:-}"
}

normalize_list() {
  # Remove comments, CRLF, empty lines, spaces around values; preserve order roughly.
  sed 's/\r$//' "$1" \
    | sed 's/[[:space:]]*#.*$//' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
    | awk 'NF' \
    | sort -u
}

is_ipv4() { echo "$1" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$'; }
is_ipv6() { echo "$1" | grep -Eq ':'; }

resolve_domain() {
  domain="$1"
  # BusyBox nslookup output differs by OpenWrt version. The parser intentionally
  # extracts only plain IPv4/IPv6 literals from answer lines.
  nslookup "$domain" 2>/dev/null \
    | awk '
      /Address[[:space:]]*[0-9]*:/ { print $NF }
      /^Address:/ { print $2 }
    ' \
    | sed 's/#.*$//' \
    | grep -E '(^([0-9]{1,3}\.){3}[0-9]{1,3}$)|:' \
    | sort -u
}

csv_or_empty_set_body() {
  # stdin -> comma-separated nft elements. Empty output means no elements.
  awk 'NF { if (n++) printf ", "; printf "%s", $0 } END { }'
}

write_set() {
  name="$1"
  type="$2"
  elements="$3"
  {
    printf '  set %s {\n' "$name"
    printf '    type %s\n' "$type"
    printf '    flags interval\n'
    if [ -n "$elements" ]; then
      printf '    elements = { %s }\n' "$elements"
    fi
    printf '  }\n\n'
  } >> "$NFT_FILE"
}

build_nft() {
  load_config
  tmp_v4="$STATE_DIR/allowed_v4.txt"
  tmp_v6="$STATE_DIR/allowed_v6.txt"
  : > "$tmp_v4"
  : > "$tmp_v6"

  normalize_list "$IPS_FILE" | while IFS= read -r ip; do
    [ -z "$ip" ] && continue
    if is_ipv4 "$ip"; then echo "$ip" >> "$tmp_v4"; elif is_ipv6 "$ip"; then echo "$ip" >> "$tmp_v6"; fi
  done

  normalize_list "$DOMAINS_FILE" | while IFS= read -r domain; do
    [ -z "$domain" ] && continue
    log "resolving $domain"
    resolve_domain "$domain" | while IFS= read -r ip; do
      [ -z "$ip" ] && continue
      if is_ipv4 "$ip"; then echo "$ip" >> "$tmp_v4"; elif is_ipv6 "$ip"; then echo "$ip" >> "$tmp_v6"; fi
    done
  done

  sort -u "$tmp_v4" -o "$tmp_v4"
  sort -u "$tmp_v6" -o "$tmp_v6"
  v4_elements="$(cat "$tmp_v4" | csv_or_empty_set_body)"
  v6_elements="$(cat "$tmp_v6" | csv_or_empty_set_body)"

  cat > "$NFT_FILE" <<NFT
#!/usr/sbin/nft -f
# Generated by edu-whitelist. Do not edit manually.
# Edit $DOMAINS_FILE, $IPS_FILE or $CONF_FILE, then run: edu-whitelist update

table inet $TABLE_NAME {
NFT
  write_set "allowed_v4" "ipv4_addr" "$v4_elements"
  if [ "$ENABLE_IPV6" = "1" ]; then
    write_set "allowed_v6" "ipv6_addr" "$v6_elements"
  fi

  cat >> "$NFT_FILE" <<NFT
  chain forward_guard {
    type filter hook forward priority -150; policy accept;

    # Only restrict student LAN -> WAN traffic. Local LAN traffic and router input are not touched.
    iifname "$LAN_IF" oifname "$WAN_IF" ct state established,related accept
    iifname "$LAN_IF" oifname "$WAN_IF" ip daddr @allowed_v4 accept
NFT
  if [ "$ENABLE_IPV6" = "1" ]; then
    cat >> "$NFT_FILE" <<NFT
    iifname "$LAN_IF" oifname "$WAN_IF" ip6 daddr @allowed_v6 accept
NFT
  else
    cat >> "$NFT_FILE" <<NFT
    iifname "$LAN_IF" oifname "$WAN_IF" meta nfproto ipv6 counter drop comment "edu whitelist: IPv6 disabled"
NFT
  fi
  cat >> "$NFT_FILE" <<NFT
    iifname "$LAN_IF" oifname "$WAN_IF" counter drop comment "edu whitelist: blocked by default"
  }
}
NFT
}

apply_nft() {
  build_nft
  if ! nft -c -f "$NFT_FILE"; then
    err "generated nftables rules did not pass syntax check: $NFT_FILE"
    exit 1
  fi
  if nft list table inet "$TABLE_NAME" >/dev/null 2>&1; then
    nft delete table inet "$TABLE_NAME"
  fi
  nft -f "$NFT_FILE"
  log "rules applied"
  status
}

install_service() {
  require_root
  ensure_dirs
  install -m 0755 "$0" /usr/bin/edu-whitelist
  cat > "$INIT_FILE" <<'INIT'
#!/bin/sh /etc/rc.common

START=19
STOP=89
USE_PROCD=0

start() {
  /usr/bin/edu-whitelist update
}

stop() {
  /usr/bin/edu-whitelist stop
}

reload() {
  /usr/bin/edu-whitelist update
}
INIT
  chmod +x "$INIT_FILE"
  "$INIT_FILE" enable >/dev/null 2>&1 || true
  log "installed to /usr/bin/edu-whitelist"
  log "edit $DOMAINS_FILE and $IPS_FILE, then run: edu-whitelist update"
}

uninstall_all() {
  require_root
  stop_rules
  [ -x "$INIT_FILE" ] && "$INIT_FILE" disable >/dev/null 2>&1 || true
  rm -f "$INIT_FILE"
  rm -f /usr/bin/edu-whitelist
  # Keep config by default? For true uninstall requested, remove it.
  rm -rf "$BASE_DIR" "$STATE_DIR"
  if [ -f "$CRON_FILE" ]; then
    sed -i '/edu-whitelist update/d' "$CRON_FILE"
    /etc/init.d/cron restart >/dev/null 2>&1 || true
  fi
  log "uninstalled"
}

stop_rules() {
  if nft list table inet "$TABLE_NAME" >/dev/null 2>&1; then
    nft delete table inet "$TABLE_NAME"
    log "rules removed from nftables"
  else
    log "rules are not loaded"
  fi
}

status() {
  load_config
  printf '\nConfig:\n'
  printf '  LAN_IF=%s\n  WAN_IF=%s\n  ENABLE_IPV6=%s\n' "$LAN_IF" "$WAN_IF" "$ENABLE_IPV6"
  printf '\nWhitelist files:\n'
  printf '  domains: %s entries\n' "$(normalize_list "$DOMAINS_FILE" | wc -l)"
  printf '  ips:     %s entries\n' "$(normalize_list "$IPS_FILE" | wc -l)"
  printf '\nLoaded rules:\n'
  if nft list table inet "$TABLE_NAME" >/dev/null 2>&1; then
    nft list table inet "$TABLE_NAME" | sed 's/^/  /'
  else
    printf '  not loaded\n'
  fi
}

add_unique() {
  file="$1"
  value="$2"
  ensure_dirs
  touch "$file"
  if normalize_list "$file" | grep -Fxq "$value"; then
    log "already exists: $value"
  else
    printf '%s\n' "$value" >> "$file"
    log "added: $value"
  fi
}

remove_value() {
  file="$1"
  value="$2"
  ensure_dirs
  tmp="$STATE_DIR/remove.tmp"
  normalize_list "$file" | grep -Fxv "$value" > "$tmp" || true
  cat "$tmp" > "$file"
  log "removed if existed: $value"
}

pull_domains() {
  load_config
  url="${1:-$REMOTE_DOMAINS_URL}"
  if [ -z "$url" ]; then
    err "URL is empty. Pass URL as argument or set REMOTE_DOMAINS_URL in $CONF_FILE"
    exit 1
  fi
  tmp="$STATE_DIR/domains.remote"
  if command -v wget >/dev/null 2>&1; then
    wget -q -O "$tmp" "$url"
  else
    err "wget is required for pull"
    exit 1
  fi
  normalize_list "$tmp" > "$DOMAINS_FILE"
  log "domains pulled from $url"
}

setup_cron() {
  load_config
  hour="${1:-$AUTO_UPDATE_HOUR}"
  mkdir -p /etc/crontabs
  touch "$CRON_FILE"
  sed -i '/edu-whitelist update/d' "$CRON_FILE"
  printf '0 %s * * * /usr/bin/edu-whitelist update >/tmp/edu-whitelist-cron.log 2>&1\n' "$hour" >> "$CRON_FILE"
  /etc/init.d/cron enable >/dev/null 2>&1 || true
  /etc/init.d/cron restart >/dev/null 2>&1 || true
  log "daily auto-update enabled at hour $hour"
}

usage() {
  cat <<USAGE
Usage: edu-whitelist <command> [argument]

Commands:
  install                 install script and init.d service on router
  update                  resolve domains and apply nftables whitelist
  stop                    remove whitelist nftables table, without deleting files
  uninstall               remove service, command, config and nftables table
  status                  show config, whitelist counters and loaded nftables rules

  add-domain DOMAIN       add domain to whitelist and apply update
  remove-domain DOMAIN    remove domain from whitelist and apply update
  add-ip IP_OR_CIDR       add static IP/CIDR to whitelist and apply update
  remove-ip IP_OR_CIDR    remove static IP/CIDR from whitelist and apply update
  pull [URL]              replace domains.txt from URL, then apply update
  cron [HOUR]             enable daily update through cron, default from config

Files:
  $DOMAINS_FILE
  $IPS_FILE
  $CONF_FILE
USAGE
}

main() {
  cmd="${1:-}"
  case "$cmd" in
    install) install_service ;;
    update) require_root; apply_nft ;;
    stop) require_root; stop_rules ;;
    uninstall) uninstall_all ;;
    status) status ;;
    add-domain) [ $# -eq 2 ] || { usage; exit 1; }; add_unique "$DOMAINS_FILE" "$2"; apply_nft ;;
    remove-domain) [ $# -eq 2 ] || { usage; exit 1; }; remove_value "$DOMAINS_FILE" "$2"; apply_nft ;;
    add-ip) [ $# -eq 2 ] || { usage; exit 1; }; add_unique "$IPS_FILE" "$2"; apply_nft ;;
    remove-ip) [ $# -eq 2 ] || { usage; exit 1; }; remove_value "$IPS_FILE" "$2"; apply_nft ;;
    pull) require_root; pull_domains "${2:-}"; apply_nft ;;
    cron) require_root; setup_cron "${2:-}" ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
